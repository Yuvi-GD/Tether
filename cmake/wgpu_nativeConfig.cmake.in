# wgpu_nativeConfig.cmake
# Generated by Tether's CMakeLists.txt — do not edit manually.
#
# This file allows Meson's dependency('wgpu_native') to find the wgpu-native
# pre-built binary when using the CMake fallback lookup method.
#
# Meson looks for this file in the paths listed by CMAKE_PREFIX_PATH.

set(WGPU_DIR "@WGPU_DIR@")

# Create an IMPORTED target that Meson's CMake dependency() call can consume
if(NOT TARGET wgpu_native::wgpu_native)
    add_library(wgpu_native::wgpu_native SHARED IMPORTED GLOBAL)

    set_target_properties(wgpu_native::wgpu_native PROPERTIES
        IMPORTED_LOCATION             "@WGPU_SHARED@"
        IMPORTED_IMPLIB               "@WGPU_IMPLIB@"
        INTERFACE_INCLUDE_DIRECTORIES "@WGPU_DIR@/include"
    )
endif()

# Also set plain variables for projects that use find_package() without targets
set(wgpu_native_FOUND        TRUE)
set(wgpu_native_INCLUDE_DIRS "@WGPU_DIR@/include")
set(wgpu_native_LIBRARIES    "@WGPU_IMPLIB@")
set(wgpu_native_VERSION      "@WGPU_VERSION@")
